{
  "kind": "collectionType",
  "collectionName": "articles",
  "info": {
    "singularName": "article",
    "pluralName": "articles",
    "displayName": "Article",
    "description": "Articles du blog : actualités, guides pratiques, ressources pédagogiques"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "titre": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "titre",
      "required": true
    },
    "chapo": {
      "type": "text",
      "maxLength": 220,
      "required": true,
      "regex": null
    },
    "contenu": {
      "type": "blocks"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "categorie": {
      "type": "enumeration",
      "enum": ["Actualités", "Formation", "Guide", "Ressource", "Job Dating"],
      "default": "Actualités",
      "required": true
    },
    "tempsLecture": {
      "type": "string",
      "default": "5 min"
    },
    "aLaUne": {
      "type": "boolean",
      "default": false
    },
    "auteur": {
      "type": "string"
    },
    "datePublication": {
      "type": "date",
      "required": true
    }
  }
}