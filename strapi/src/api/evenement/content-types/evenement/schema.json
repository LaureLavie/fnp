{
  "kind": "collectionType",
  "collectionName": "evenements",
  "info": {
    "singularName": "evenement",
    "pluralName": "evenements",
    "displayName": "Événement",
    "description": "Événements et rendez-vous : job dating, portes ouvertes, webinaires, salons"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "titre": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "titre"
    },
    "description": {
      "type": "text"
    },
    "dateEvenement": {
      "type": "datetime",
      "required": true
    },
    "lieu": {
      "type": "string"
    },
    "typeEvenement": {
      "type": "enumeration",
      "enum": ["Job Dating", "Portes ouvertes", "Webinaire", "Salon", "Autre"],
      "default": "Autre",
      "required": true
    },
    "lienExterne": {
      "type": "string"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    }
  }
}